# Common, non-secret application defaults
# This file IS committed to git

# CORS (local dev default, override in production)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Cache settings
REDIS_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Development bypass (default: disabled, enable in .env.development)
DEV_BYPASS_EMAIL_VERIFICATION=false
DEV_BYPASS_VERIFICATION_CODE=888888

# LangSmith configuration
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=financial-agent

# Agent Maestro defaults (W8) - override MAESTRO_BASE_URL in docker-compose for container access
MAESTRO_BASE_URL=http://localhost:23333/api/anthropic
MAESTRO_AUTH_TOKEN=Powered by Agent Maestro

# Per-role model assignments (override to experiment)
MODEL_DEEP_PLANNER=claude-opus-4-7
MODEL_SUB_DEBATER=claude-opus-4-7
MODEL_PORTFOLIO_DECISIONS=claude-opus-4-7
MODEL_SUB_FINANCIAL=claude-sonnet-4-6
MODEL_SUB_TECHNICAL=claude-sonnet-4-6
MODEL_REACT_AGENT=claude-sonnet-4-6
MODEL_PORTFOLIO_RESEARCH=claude-sonnet-4-6
MODEL_VERDICT=claude-sonnet-4-6
MODEL_SUB_NEWS=claude-haiku-4-5
MODEL_SIMPLE_CHAT=claude-haiku-4-5
MODEL_SUMMARY=claude-haiku-4-5
