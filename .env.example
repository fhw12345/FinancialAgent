# Financial Agent Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development

# =============================================================================
# Database Configuration
# =============================================================================
MONGODB_URL=mongodb://mongodb:27017/financial_agent
REDIS_URL=redis://redis:6379

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# LangSmith (optional, off by default)
# =============================================================================
LANGSMITH_TRACING_V2=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=financial-agent

# =============================================================================
# Optional: Langfuse LLM observability (off by default)
# =============================================================================
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# =============================================================================
# Agent Maestro (LLM gateway - all LLM traffic routes through here, W8)
# In Docker the backend reaches the host gateway at host.docker.internal.
# =============================================================================
MAESTRO_BASE_URL=http://host.docker.internal:23333/api/anthropic
MAESTRO_AUTH_TOKEN=Powered by Agent Maestro

# Per-role model assignments (defaults are sensible; override only to experiment)
MODEL_DEEP_PLANNER=claude-opus-4-7
MODEL_SUB_DEBATER=claude-opus-4-7
MODEL_PORTFOLIO_DECISIONS=claude-opus-4-7
MODEL_SUB_FINANCIAL=claude-sonnet-4-6
MODEL_SUB_TECHNICAL=claude-sonnet-4-6
MODEL_REACT_AGENT=claude-sonnet-4-6
MODEL_PORTFOLIO_RESEARCH=claude-sonnet-4-6
MODEL_VERDICT=claude-sonnet-4-6
MODEL_SUB_NEWS=claude-haiku-4-5
MODEL_SIMPLE_CHAT=claude-haiku-4-5
MODEL_SUMMARY=claude-haiku-4-5

# =============================================================================
# Market Data (free sources by default; Alpha Vantage / FRED keys optional)
# =============================================================================
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# =============================================================================
# Cache & Rate Limiting
# =============================================================================
REDIS_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8000

# =============================================================================
# Development Tools
# =============================================================================
DEBUG=false
REACT_QUERY_DEVTOOLS=true
