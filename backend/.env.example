# Backend env template - copy to backend/.env.development for local overrides
# Most settings live in backend/.env.base (committed). This file shows the
# secrets / overrides you may need.

# === Environment ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Database ===
MONGODB_URL=mongodb://mongodb:27017/financial_agent
REDIS_URL=redis://redis:6379/0

# === Agent Maestro (LLM gateway, required) ===
MAESTRO_BASE_URL=http://host.docker.internal:23333/api/anthropic
MAESTRO_AUTH_TOKEN=Powered by Agent Maestro

# === Per-role model assignments (cross-vendor; defaults work, override to experiment) ===
# Claude (deep reasoning / verdict / chat)
MODEL_DEEP_PLANNER=claude-opus-4.7
MODEL_PORTFOLIO_DECISIONS=claude-opus-4.7
MODEL_VERDICT=claude-opus-4.7
MODEL_SUB_TECHNICAL=claude-sonnet-4.6
MODEL_SIMPLE_CHAT=claude-haiku-4.5
# GPT (tool orchestration & structured extraction)
MODEL_REACT_AGENT=gpt-5.5
MODEL_SUB_FINANCIAL=gpt-5.5
MODEL_PORTFOLIO_RESEARCH=gpt-5.5
# Gemini (long-context news/summary + cross-vendor debater)
MODEL_SUB_DEBATER=gemini-3.1-pro-preview
MODEL_SUB_NEWS=gemini-3-flash-preview
MODEL_SUMMARY=gemini-3-flash-preview

# === Optional: paid data sources (yfinance is the free default) ===
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
EXA_API_KEY=
FINNHUB_API_KEY=

# === Optional: observability ===
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# === App ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
