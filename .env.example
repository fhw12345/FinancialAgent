# Financial Agent (personal local fork) - environment template
# Copy to .env and fill in. Most defaults work out of the box.

# === Environment ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Database ===
MONGODB_URL=mongodb://mongodb:27017/financial_agent
REDIS_URL=redis://redis:6379/0

# === Agent Maestro (LLM gateway, required) ===
# In Docker, the backend reaches the host gateway via host.docker.internal.
MAESTRO_BASE_URL=http://host.docker.internal:23333/api/anthropic
MAESTRO_AUTH_TOKEN=Powered by Agent Maestro

# === Per-role model assignments (defaults work; override to experiment) ===
MODEL_DEEP_PLANNER=claude-opus-4-7
MODEL_SUB_DEBATER=claude-opus-4-7
MODEL_PORTFOLIO_DECISIONS=claude-opus-4-7
MODEL_SUB_FINANCIAL=claude-sonnet-4-6
MODEL_SUB_TECHNICAL=claude-sonnet-4-6
MODEL_REACT_AGENT=claude-sonnet-4-6
MODEL_PORTFOLIO_RESEARCH=claude-sonnet-4-6
MODEL_VERDICT=claude-sonnet-4-6
MODEL_SUB_NEWS=claude-haiku-4-5
MODEL_SIMPLE_CHAT=claude-haiku-4-5
MODEL_SUMMARY=claude-haiku-4-5

# === Optional: paid data sources (yfinance is the free default) ===
ALPHA_VANTAGE_API_KEY=    # optional faster path; yfinance fallback if blank
FRED_API_KEY=             # required for FRED macro indicators (free signup)

# === Optional: observability ===
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# === App ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
REDIS_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# === Frontend ===
VITE_API_URL=http://localhost:8000
