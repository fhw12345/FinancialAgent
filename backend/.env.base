# Common, non-secret application defaults
# This file IS committed to git

# CORS (local dev default, override in production)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Cache settings
REDIS_TTL_SECONDS=3600

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Development bypass (default: disabled, enable in .env.development)
DEV_BYPASS_EMAIL_VERIFICATION=false
DEV_BYPASS_VERIFICATION_CODE=888888

# LangSmith configuration
LANGSMITH_TRACING_V2=true
LANGSMITH_PROJECT=financial-agent

# Agent Maestro defaults (W8) - override MAESTRO_BASE_URL in docker-compose for container access
MAESTRO_BASE_URL=http://localhost:23333/api/anthropic
MAESTRO_AUTH_TOKEN=Powered by Agent Maestro

# Per-role model assignments — top-of-line per vendor, cross-vendor preserved
# for adversarial debate diversity. Override here to experiment.
#
# — Anthropic Opus 4.7 family (xhigh = extra reasoning budget; 1m-internal = 935k context)
MODEL_DEEP_PLANNER=claude-opus-4.7-xhigh
MODEL_REACT_AGENT=claude-opus-4.7-1m-internal
MODEL_PORTFOLIO_DECISIONS=claude-opus-4.7-xhigh
MODEL_VERDICT=claude-opus-4.7-xhigh
MODEL_SUB_TECHNICAL=claude-opus-4.7
MODEL_SIMPLE_CHAT=claude-haiku-4.5
# — GPT-5.5 (OpenAI flagship for structured extraction)
MODEL_SUB_FINANCIAL=gpt-5.5
MODEL_PORTFOLIO_RESEARCH=gpt-5.5
# — Gemini 3.1 Pro (cross-vendor diversity for adversarial debate)
MODEL_SUB_DEBATER=gemini-3.1-pro-preview
MODEL_SUB_NEWS=gemini-3.1-pro-preview
MODEL_SUMMARY=gemini-3.1-pro-preview
